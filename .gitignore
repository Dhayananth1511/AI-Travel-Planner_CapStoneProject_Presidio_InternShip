# ===========================
# Node.js + dependencies
# ===========================
# node_modules is the folder where npm installs packages
# It's HUGE (can be 500MB+) and gets regenerated with npm install
# So we NEVER commit it — only commit package.json which lists what's needed
node_modules/

# ===========================
# Environment / Secrets
# ===========================
# These files have your API keys, DB passwords, JWT secrets
# If this goes to GitHub, anyone can steal them and wreck your accounts
.env
.env.local
.env.production
.env.development

# ===========================
# Build outputs
# ===========================
# These are auto-generated by the build tool — no point tracking them
dist/
build/
.next/

# ===========================
# Logs
# ===========================
*.log
logs/
npm-debug.log*
yarn-debug.log*

# ===========================
# OS files (useless noise)
# ===========================
.DS_Store         # Mac metadata
Thumbs.db         # Windows thumbnail cache
Desktop.ini

# ===========================
# IDE / Editor
# ===========================
.vscode/settings.json
.idea/

# ===========================
# Terraform
# ===========================
# .terraform/ folder contains downloaded providers (like node_modules — large)
# *.tfstate files contain your ACTUAL AWS infrastructure state — sensitive!
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl
# terraform.tfvars contains ALL your real secrets — NEVER commit this!
terraform.tfvars
infrastructure/terraform.tfvars

# ===========================
# Docker
# ===========================
# Don't commit local Docker override files
docker-compose.override.yml

# Implementation plans
implementation_plan.md
implementation_plan1.md

walkthrough.md
