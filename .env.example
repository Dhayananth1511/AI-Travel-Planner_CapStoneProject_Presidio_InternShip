# Application Configurations
PORT=5000
NODE_ENV=development

# Security & JWT Tokens
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# Database & Caching
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/travel_planner?retryWrites=true&w=majority
REDIS_URL=redis://localhost:6379

# AI & LLM Inference
GROQ_API_KEY=gsk_your_groq_api_key_here

# Maps & Locations (Google Cloud Platform)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Calendar Integration (Google OAuth2)
GOOGLE_CALENDAR_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CALENDAR_CLIENT_SECRET=GOCSPX-your_google_client_secret_here
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Transportation & Hotels (If upgrading from mocks to real APIs)
AMADEUS_CLIENT_ID=your_amadeus_api_key_here
AMADEUS_CLIENT_SECRET=your_amadeus_api_secret_here
NAVITIA_TOKEN=your_navitia_token_here
